# LLM Configuration
# Required for RITS (Research IT Services) LLM backend
RITS_API_KEY=<RITS_API_KEY>
RITS_MODEL=<YOUR_MODEL>
RITS_API_URL=<RITS_API_URL>

# Tiered model configuration (optional — overrides defaults in config.py)
# Heavy model for benchmark card composition (default: DeepSeek V3.2)
# RITS_COMPOSER_MODEL=deepseek-ai/DeepSeek-V3.2
# Lightweight model for RAG reranking, query reformulation, atomization (default: Granite 3.3 8B)
# RITS_LIGHT_MODEL=ibm-granite/granite-3.3-8b-instruct

# Optional: Ollama Configuration
# Uncomment if using local Ollama instead of RITS
# OLLAMA_API_URL=http://localhost:11434
# OLLAMA_MODEL= <YOUR_MODEL>
# for the OLLAMA model something like gemma3:27b is recommended
